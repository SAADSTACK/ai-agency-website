{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/services",
      "destination": "/public/services.html"
    },
    {
      "source": "/insights",
      "destination": "/public/insights.html"
    },
    {
      "source": "/contact",
      "destination": "/public/contact.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
